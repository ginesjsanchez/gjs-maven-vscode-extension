{
    "New pom.xml (basic)": {
        "prefix": "pom-basic",
        "body": [
            "<?xml version=\"1.0\" encoding=\"UTF-8\"?>",
            "<project xmlns=\"http://maven.apache.org/POM/4.0.0\"",
            "         xmlns:xsi=\"http://www.w3.org/2001/XMLSchema-instance\"",
            "         xsi:schemaLocation=\"http://maven.apache.org/POM/4.0.0 https://maven.apache.org/xsd/maven-4.0.0.xsd\">",
            "    <modelVersion>4.0.0</modelVersion>",
            "",
            "    <groupId>${1:com.example}</groupId>",
            "    <artifactId>${2:my-project}</artifactId>",
            "    <version>${3:1.0.0-SNAPSHOT}</version>",
            "    <packaging>${4|jar,war,pom,nar|}</packaging>",
            "",
            "    <name>${2}</name>",
            "    <description>${5:Project description}</description>",
            "",
            "    <properties>",
            "        <java.version>${6:17}</java.version>",
            "        <maven.compiler.source>${6}</maven.compiler.source>",
            "        <maven.compiler.target>${6}</maven.compiler.target>",
            "        <project.build.sourceEncoding>UTF-8</project.build.sourceEncoding>",
            "    </properties>",
            "",
            "    <dependencies>",
            "        $0",
            "    </dependencies>",
            "",
            "</project>"
        ],
        "description": "Basic Maven POM template"
    },
    "New pom.xml (Spring Boot)": {
        "prefix": "pom-spring-boot",
        "body": [
            "<?xml version=\"1.0\" encoding=\"UTF-8\"?>",
            "<project xmlns=\"http://maven.apache.org/POM/4.0.0\"",
            "         xmlns:xsi=\"http://www.w3.org/2001/XMLSchema-instance\"",
            "         xsi:schemaLocation=\"http://maven.apache.org/POM/4.0.0 https://maven.apache.org/xsd/maven-4.0.0.xsd\">",
            "    <modelVersion>4.0.0</modelVersion>",
            "",
            "    <parent>",
            "        <groupId>org.springframework.boot</groupId>",
            "        <artifactId>spring-boot-starter-parent</artifactId>",
            "        <version>3.2.1</version>",
            "        <relativePath/>",
            "    </parent>",
            "",
            "    <groupId>${1:com.example}</groupId>",
            "    <artifactId>${2:demo}</artifactId>",
            "    <version>0.0.1-SNAPSHOT</version>",
            "    <name>${2}</name>",
            "",
            "    <properties>",
            "        <java.version>17</java.version>",
            "    </properties>",
            "",
            "    <dependencies>",
            "        <dependency>",
            "            <groupId>org.springframework.boot</groupId>",
            "            <artifactId>spring-boot-starter-web</artifactId>",
            "        </dependency>",
            "        <dependency>",
            "            <groupId>org.springframework.boot</groupId>",
            "            <artifactId>spring-boot-starter-test</artifactId>",
            "            <scope>test</scope>",
            "        </dependency>",
            "        $0",
            "    </dependencies>",
            "",
            "    <build>",
            "        <plugins>",
            "            <plugin>",
            "                <groupId>org.springframework.boot</groupId>",
            "                <artifactId>spring-boot-maven-plugin</artifactId>",
            "            </plugin>",
            "        </plugins>",
            "    </build>",
            "",
            "</project>"
        ],
        "description": "Spring Boot Maven POM template"
    },
    "New pom.xml (C++ NAR)": {
        "prefix": "pom-cpp-nar",
        "body": [
            "<?xml version=\"1.0\" encoding=\"UTF-8\"?>",
            "<project xmlns=\"http://maven.apache.org/POM/4.0.0\"",
            "         xmlns:xsi=\"http://www.w3.org/2001/XMLSchema-instance\"",
            "         xsi:schemaLocation=\"http://maven.apache.org/POM/4.0.0 https://maven.apache.org/xsd/maven-4.0.0.xsd\">",
            "    <modelVersion>4.0.0</modelVersion>",
            "",
            "    <groupId>${1:com.example}</groupId>",
            "    <artifactId>${2:my-native-lib}</artifactId>",
            "    <version>${3:1.0.0-SNAPSHOT}</version>",
            "    <packaging>nar</packaging>",
            "",
            "    <build>",
            "        <plugins>",
            "            <plugin>",
            "                <groupId>com.github.maven-nar</groupId>",
            "                <artifactId>nar-maven-plugin</artifactId>",
            "                <version>3.10.1</version>",
            "                <extensions>true</extensions>",
            "                <configuration>",
            "                    <libraries>",
            "                        <library>",
            "                            <type>${4|shared,static,jni|}</type>",
            "                        </library>",
            "                    </libraries>",
            "                    <cpp>",
            "                        <name>g++</name>",
            "                        <options>",
            "                            <option>-std=c++${5|14,17,20|}</option>",
            "                            <option>-O2</option>",
            "                        </options>",
            "                    </cpp>",
            "                </configuration>",
            "            </plugin>",
            "        </plugins>",
            "    </build>",
            "",
            "</project>"
        ],
        "description": "C++ project using nar-maven-plugin"
    },
    "New pom.xml (Python/Jython)": {
        "prefix": "pom-python",
        "body": [
            "<?xml version=\"1.0\" encoding=\"UTF-8\"?>",
            "<project xmlns=\"http://maven.apache.org/POM/4.0.0\"",
            "         xmlns:xsi=\"http://www.w3.org/2001/XMLSchema-instance\"",
            "         xsi:schemaLocation=\"http://maven.apache.org/POM/4.0.0 https://maven.apache.org/xsd/maven-4.0.0.xsd\">",
            "    <modelVersion>4.0.0</modelVersion>",
            "",
            "    <groupId>${1:com.example}</groupId>",
            "    <artifactId>${2:my-python-project}</artifactId>",
            "    <version>${3:1.0.0-SNAPSHOT}</version>",
            "    <packaging>jar</packaging>",
            "",
            "    <dependencies>",
            "        <dependency>",
            "            <groupId>org.python</groupId>",
            "            <artifactId>jython-standalone</artifactId>",
            "            <version>2.7.3</version>",
            "        </dependency>",
            "        $0",
            "    </dependencies>",
            "",
            "    <build>",
            "        <plugins>",
            "            <plugin>",
            "                <groupId>org.codehaus.mojo</groupId>",
            "                <artifactId>exec-maven-plugin</artifactId>",
            "                <version>3.1.1</version>",
            "                <configuration>",
            "                    <executable>python3</executable>",
            "                    <workingDirectory>src/main/python</workingDirectory>",
            "                    <arguments>",
            "                        <argument>main.py</argument>",
            "                    </arguments>",
            "                </configuration>",
            "            </plugin>",
            "        </plugins>",
            "    </build>",
            "",
            "</project>"
        ],
        "description": "Python/Jython project via exec-maven-plugin"
    },
